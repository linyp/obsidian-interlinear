{
  "name": "interlinear",
  "version": "0.1.0",
  "description": "Interlinear — reading-mode immersive translation for Obsidian: render translations alongside the original, never modifying your notes. BYOK (DeepSeek). Inspired by immersive translation; not affiliated.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "interlinear",
    "translation",
    "immersive-translation",
    "deepseek"
  ],
  "author": "Yupeng Lin",
  "license": "MIT",
  "homepage": "https://github.com/linyp/obsidian-interlinear#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/linyp/obsidian-interlinear.git"
  },
  "bugs": {
    "url": "https://github.com/linyp/obsidian-interlinear/issues"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "builtin-modules": "^5.2.0",
    "esbuild": "^0.28.0",
    "obsidian": "^1.13.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
